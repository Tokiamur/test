local mockState = {
    active = false,
    tradePartner = nil,
    lastOffer = nil,
    pendingTradeRequest = false,
}

local TradeModule = nil
local TradeGUI = nil
local TradeRemote = nil

local function waitForTradeModule()
    local success, result = xpcall(function()
        return require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("TradeModule"))
    end, function(err)
        warn("[MM2 TRADE] Error loading TradeModule:", err)
    end)
    return success and result or nil
end

local function waitForTradeGUI()
    local gui = nil
    for i = 1, 50 do
        gui = LocalPlayer:FindFirstChild("PlayerGui") and (
            LocalPlayer.PlayerGui:FindFirstChild("TradeGUI_Phone") or 
            LocalPlayer.PlayerGui:FindFirstChild("TradeGUI")
        )
        if gui then
            return gui
        end
        task.wait(0.1)
    end
    return nil
end

local function getTradeRemote()
    return ReplicatedStorage:FindFirstChild("Trade")
end

local function init()
    print("[MM2 TRADE] Инициализация...")
    
    TradeModule = waitForTradeModule()
    if not TradeModule then
        warn("[MM2 TRADE] Не удалось загрузить TradeModule")
        return false
    end
    
    print("[MM2 TRADE] === TRADE MODULE FUNCTIONS ===")
    for k, v in pairs(TradeModule) do
        if type(v) == "function" then
            print("  📌 " .. k .. "()")
        end
    end
    print("[MM2 TRADE] === END MODULE FUNCTIONS ===")
    
    TradeGUI = waitForTradeGUI()
    if not TradeGUI then
        warn("[MM2 TRADE] Не удалось найти TradeGUI")
        return false
    end
    
    TradeRemote = getTradeRemote()
    if not TradeRemote then
        warn("[MM2 TRADE] Не удалось найти Trade удалённые функции")
        return false
    end
    
    print("[MM2 TRADE] === TRADE REMOTES ===")
    for _, child in pairs(TradeRemote:GetChildren()) do
        print("  📡 " .. child.Name .. " (" .. child.ClassName .. ")")
    end
    print("[MM2 TRADE] === END REMOTES ===")
    
    print("[MM2 TRADE] Готово к работе")
    return true
end

local function simulateTradeRequest(senderName)
    if not TradeModule or not TradeGUI then
        return warn("[MM2 TRADE] Trade система не инициализирована")
    end
    
    print("[MM2 TRADE] Симуляция Trade Request от " .. senderName)
    
    if mockState.pendingTradeRequest then
        return warn("[MM2 TRADE] Уже есть активный Trade Request")
    end
    
    mockState.pendingTradeRequest = true
    mockState.tradePartner = senderName
    
    task.wait(CONFIG.AUTO_ACCEPT_DELAY)
    
    if TradeModule.UpdateTradeRequestWindow then
        TradeModule.UpdateTradeRequestWindow("ReceivingRequest", {
            Sender = {
                Name = senderName
            }
        })
        print("[MM2 TRADE] Trade Request UI обновлён")
    end
    
    if TradeModule.ConnectRequestWindow then
        pcall(TradeModule.ConnectRequestWindow)
    end
    
    return true
end

local function startTradeScreen()
    if not mockState.tradePartner then
        return warn("[MM2 TRADE] Нет партнёра для торговли")
    end
    
    print("[MM2 TRADE] Открываю торговый экран с " .. mockState.tradePartner)
    
    task.wait(0.5)
    
    local success = false
 
    if TradeModule and TradeModule.SendTradeRequest then
        pcall(function()
            local result = TradeModule.SendTradeRequest(mockState.tradePartner)
            print("[MM2 TRADE] ✓ SendTradeRequest() вызвана, результат: " .. tostring(result))
            success = true
        end)
    end
    

    if TradeGUI then
        local tradeGridLayout = TradeGUI:FindFirstChild("TradeGridLayout")
        if tradeGridLayout then
            pcall(function()
                print("[MM2 TRADE] ✓ Найден TradeGridLayout")
                -- Попробуем активировать его
                if tradeGridLayout:FindFirstChild("Visible") then
                    tradeGridLayout.Visible = true
                end
            end)
        else
            print("[MM2 TRADE] TradeGridLayout не найден")
        end
    end
    

    if TradeModule and TradeModule.UpdateTradeInventory then
        pcall(function()
            TradeModule.UpdateTradeInventory()
            print("[MM2 TRADE] ✓ UpdateTradeInventory() вызвана")
        end)
    end
    

    if TradeModule and TradeModule.ConnectTabButtons then
        pcall(function()
            TradeModule.ConnectTabButtons()
            print("[MM2 TRADE] ✓ ConnectTabButtons() вызвана")
        end)
    end
    

    if TradeModule and TradeModule.ConnectOfferButtons then
        pcall(function()
            TradeModule.ConnectOfferButtons()
            print("[MM2 TRADE] ✓ ConnectOfferButtons() вызвана")
        end)
    end
    

    if TradeModule and TradeModule.UpdateTradeRequestWindow then
        pcall(function()
            TradeModule.UpdateTradeRequestWindow("Trading", {
                Partner = mockState.tradePartner
            })
            print("[MM2 TRADE] ✓ UpdateTradeRequestWindow(Trading) вызвана")
            success = true
        end)
    end
    
    mockState.active = success
    
    if success then
        print("[MM2 TRADE] ✓✓✓ Торговля инициирована!")
    else
        warn("[MM2 TRADE] ❌ Ошибка при открытии торговли")
    end
    
    return success
end


local function autoAcceptTradeRequest()
    if not mockState.pendingTradeRequest then
        return warn("[MM2 TRADE] Нет активного Trade Request")
    end
    
    print("[MM2 TRADE] Auto-accept Trade Request")
    
    task.wait(CONFIG.AUTO_ACCEPT_DELAY)
    

    if TradeRemote and TradeRemote:FindFirstChild("AcceptRequest") then
        TradeRemote.AcceptRequest:FireServer()
    end
    
    mockState.pendingTradeRequest = false
    
    -- Автоматически открываем торговый экран
    task.wait(0.5)
    startTradeScreen()
    
    return true
end


local function autoConfirmTrade()
    if not mockState.active then
        return warn("[MM2 TRADE] Нет активной торговли")
    end
    
    print("[MM2 TRADE] Auto-confirm Trade")
    
    task.wait(CONFIG.AUTO_CONFIRM_DELAY)
    
    if TradeRemote and TradeRemote:FindFirstChild("AcceptTrade") then
        TradeRemote.AcceptTrade:FireServer(game.PlaceId * 3, mockState.lastOffer)
    end
    
    return true
end


local function hookTradeEvents()
    if not TradeRemote then
        return
    end
    
    if TradeRemote:FindFirstChild("StartTrade") then
        TradeRemote.StartTrade.OnClientEvent:Connect(function(tradeState, partnerName)
            print("[MM2 TRADE] Торговля началась с " .. partnerName)
            mockState.active = true
            mockState.tradePartner = partnerName
            mockState.lastOffer = tradeState and tradeState.LastOffer or nil
        end)
    end
    
    if TradeRemote:FindFirstChild("UpdateTrade") then
        TradeRemote.UpdateTrade.OnClientEvent:Connect(function(tradeState)
            if tradeState then
                mockState.lastOffer = tradeState.LastOffer
            end
        end)
    end
    
    if TradeRemote:FindFirstChild("DeclineTrade") then
        TradeRemote.DeclineTrade.OnClientEvent:Connect(function()
            print("[MM2 TRADE] Торговля отклонена")
            mockState.active = false
        end)
    end
    
    if TradeRemote:FindFirstChild("AcceptTrade") then
        TradeRemote.AcceptTrade.OnClientEvent:Connect(function(success)
            if success then
                print("[MM2 TRADE] Торговля завершена успешно")
            end
            mockState.active = false
        end)
    end
end

