    PARTNER_NAME = 'Set Nickname',
    AUTO_ACCEPT_DELAY = 0.2,
    AUTO_CONFIRM_DELAY = 0.3,
    AUTO_ACCEPT_ENABLED = false,
    AUTO_CONFIRM_ENABLED = false,
}

